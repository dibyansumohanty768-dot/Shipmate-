<!-- BOTTOM TOOLBAR -->
<div class="toolbar">
  <button class="tbtn active" id="tb-book" onclick="showTab('book',this)">
    <span class="ticon">📦</span>Book<div class="tbar"></div>
  </button>
  <button class="tbtn" id="tb-track" onclick="showTab('track',this)">
    <span class="ticon">🔍</span>Track<div class="tbar"></div>
  </button>
  <button class="tbtn" id="tb-partner" onclick="showTab('partner',this)">
    <span class="ticon">🚗</span>Partner<div class="tbar"></div>
  </button>
  <button class="tbtn" id="tb-profile" onclick="showTab('profile',this);loadProfile()">
    <span class="ticon">👤</span>Profile<div class="tbar"></div>
  </button>
</div>

<script>
// ── DATA ──────────────────────────────────────────────────────────
const vehicles=[
  {id:"bike",  icon:"🏍️",name:"Bike",       desc:"Documents & small parcels",cap:"Up to 20 kg",  price:"$3" },
  {id:"car",   icon:"🚗", name:"Car",         desc:"Bags & medium packages",   cap:"Up to 100 kg", price:"$8" },
  {id:"struck",icon:"🚐", name:"Small Truck", desc:"Furniture & appliances",   cap:"Up to 500 kg", price:"$25"},
  {id:"truck", icon:"🚛", name:"Truck",       desc:"House moves & bulk cargo", cap:"Up to 5,000 kg",price:"$80"},
];

// Fake order database — real app would fetch from server
const fakeOrders={
  "SWDEMO1":{ vehicle:"Car 🚗", status:"transit", pickupAddr:"42 Oak Avenue, Brooklyn, NY", deliveryAddr:"100 5th Ave, Manhattan, NY", sender:"John Smith", receiver:"Mary Johnson", weight:"5 kg", notes:"Handle with care", date:"Apr 23, 2026", timeline:[{done:true,label:"Order Placed",time:"8:00 AM"},{done:true,label:"Picked Up",time:"9:15 AM"},{done:true,label:"In Transit",time:"9:30 AM"},{done:false,label:"Out for Delivery",time:""},{done:false,label:"Delivered",time:""}]},
  "SWDEMO2":{ vehicle:"Bike 🏍️", status:"delivered", pickupAddr:"15 Pine Street, Queens, NY", deliveryAddr:"88 River Road, Bronx, NY", sender:"Alice Brown", receiver:"Bob White", weight:"2 kg", notes:"", date:"Apr 22, 2026", timeline:[{done:true,label:"Order Placed",time:"10:00 AM"},{done:true,label:"Picked Up",time:"10:20 AM"},{done:true,label:"In Transit",time:"10:35 AM"},{done:true,label:"Out for Delivery",time:"11:00 AM"},{done:true,label:"Delivered",time:"11:18 AM"}]},
};

// State
let userAddr="", userDisplayName="", activeVehicle=null, bookingMyRole=null, bookingOther="";
let bookingDetails={};
let ordersDB={...fakeOrders};

function $(id){return document.getElementById(id);}
function genId(){return "SW"+Math.random().toString(36).substring(2,8).toUpperCase();}

// ── ONBOARDING ────────────────────────────────────────────────────
function saveAddress(){
  const street=$("ob_street").value.trim();
  const city=$("ob_city").value.trim();
  const state=$("ob_state").value.trim();
  const zip=$("ob_zip").value.trim();
  if(!street||!city||!state||!zip){alert("Please fill in Street, City, State and ZIP to continue, or tap 'Skip for now'.");return;}
  const country=$("ob_country").value.trim();
  userAddr=street+", "+city+", "+state+" "+zip+(country?", "+country:"");
  $("onboardingOverlay").classList.add("hidden");
  $("heroAddr").textContent=userAddr;
  $("navAddr").textContent="📍 "+city;
  buildVehicleGrid();
}
function skipOnboarding(){
  userAddr="Not set";
  const ov=document.getElementById("onboardingOverlay");
  ov.classList.add("hidden");
  ov.style.display="none";
  document.getElementById("heroAddr").textContent="Set your address in Profile";
  document.getElementById("navAddr").textContent="";
  buildVehicleGrid();
}
$("ob_zip").addEventListener("keydown",e=>{if(e.key==="Enter")saveAddress();});

// ── TABS ──────────────────────────────────────────────────────────
function showTab(tab, btn){
  document.querySelectorAll(".tbtn").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  ["book","partner","track","profile"].forEach(p=>{
    $(("page-"+p)).classList.toggle("hidden", p!==tab);
  });
}

// ── PROFILE ───────────────────────────────────────────────────────
function loadProfile(){
  if(userAddr && userAddr!=="Your address"){
    const parts=userAddr.split(", ");
    if($("prof_street"))$("prof_street").value=parts[0]||"";
    if($("prof_city"))$("prof_city").value=parts[1]||"";
    const statezip=(parts[2]||"").split(" ");
    if($("prof_state"))$("prof_state").value=statezip[0]||"";
    if($("prof_zip"))$("prof_zip").value=statezip[1]||"";
    if($("prof_country"))$("prof_country").value=parts[3]||"";
  }
  const ordersWrap=$("prof_orders");
  const keys=Object.keys(ordersDB).filter(k=>!["SWDEMO1","SWDEMO2"].includes(k));
  if(!keys.length){
    ordersWrap.innerHTML=`<div style="text-align:center;padding:16px 0;font-size:13px;color:#9CA3AF;">No bookings yet. Book your first shipment!</div>`;
    return;
  }
  ordersWrap.innerHTML=keys.reverse().map(k=>{
    const o=ordersDB[k];
    const st={pending:"🟡 Pending",transit:"🔵 In Transit",delivered:"🟢 Delivered"}[o.status]||"🟡 Pending";
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #F3F4F6;">
      <div>
        <div style="font-size:13px;font-weight:700;color:#111;">${k}</div>
        <div style="font-size:12px;color:#6B7280;margin-top:2px;">${o.vehicle} · ${o.date||"Today"}</div>
      </div>
      <div style="font-size:12px;font-weight:600;">${st}</div>
    </div>`;
  }).join("");
}
function saveProfile(){
  const street=$("prof_street").value.trim();
  const city=$("prof_city").value.trim();
  const state=$("prof_state").value.trim();
  const zip=$("prof_zip").value.trim();
  if(!street||!city||!state||!zip){alert("Please fill in Street, City, State and ZIP.");return;}
  const country=$("prof_country").value.trim();
  userAddr=street+", "+city+", "+state+" "+zip+(country?", "+country:"");
  $("heroAddr").textContent=userAddr;
  $("navAddr").textContent="📍 "+city;
  $("prof_saved").style.display="block";
  setTimeout(()=>{$("prof_saved").style.display="none";},2500);
}

// ── VEHICLE GRID ──────────────────────────────────────────────────
function buildVehicleGrid(){
  $("vehicleGrid").innerHTML=vehicles.map(v=>`
    <div class="vcard" onclick="openBooking('${v.id}')">
      <span class="vcard-icon">${v.icon}</span>
      <div class="vcard-name">${v.name}</div>
      <div class="vcard-desc">${v.desc}</div>
      <div class="vcard-cap">${v.cap}</div>
      <div class="vcard-price">${v.price} <span>starting</span></div>
      <div class="vcard-tap">Book now →</div>
      <div class="vcard-bar"></div>
    </div>`).join("");
}

// ── BOOKING SHEET ─────────────────────────────────────────────────
function openBooking(vid){
  activeVehicle=vehicles.find(v=>v.id===vid);
  bookingMyRole=null; bookingOther=""; bookingDetails={};
  renderSheet(1);
  $("bookingOverlay").classList.remove("hidden");
}
function closeBooking(){$("bookingOverlay").classList.add("hidden"); activeVehicle=null;}
$("bookingOverlay").addEventListener("click",function(e){if(e.target===this)closeBooking();});

function dots(current,total){
  return '<div class="step-dots">'+Array.from({length:total},(_,i)=>`<div class="sdot${i<current?' active':''}"></div>`).join("")+'</div>';
}

function renderSheet(step){
  const v=activeVehicle;
  let h=`<div class="sheet-vtag">${v.icon} &nbsp;${v.name} &nbsp;·&nbsp; ${v.price}/start</div>`;
  h+=dots(step,4);

  if(step===1){
    h+=`
      <div class="sheet-q">Is your address the pickup or delivery point?</div>
      <div class="sheet-hint">Your saved address: <strong style="color:#111">${userAddr}</strong></div>
      <div class="choices">
        <button class="choice" onclick="chooseRole('pickup')">
          <span class="choice-emoji">📦</span>
          <span class="choice-label">Pickup</span>
          <span class="choice-hint">Collect from my address</span>
        </button>
        <button class="choice" onclick="chooseRole('delivery')">
          <span class="choice-emoji">🏠</span>
          <span class="choice-label">Delivery</span>
          <span class="choice-hint">Deliver to my address</span>
        </button>
      </div>
      <button class="btn-link" onclick="closeBooking()">← Change vehicle</button>`;
  }

  if(step===2){
    const isPickup=bookingMyRole==="pickup";
    h+=`
      <div class="sheet-q">${isPickup?"Where should we deliver it?":"Where should we pick it up from?"}</div>
      <div class="sheet-hint">${isPickup?"Enter the full address of the delivery destination.":"Enter the full address where we collect the shipment."}</div>
      <div class="fgroup">
        <label class="flabel">${isPickup?"🏠 Delivery Address":"📦 Pickup Address"}</label>
        <input class="finput hi" id="otherAddrInput" placeholder="Street address, city, zip" oninput="previewSummary()"/>
      </div>
      <div class="fgroup">
        <label class="flabel">${isPickup?"Receiver's Name":"Sender's Name"}</label>
        <input class="finput" id="otherName" placeholder="${isPickup?"Who receives the shipment?":"Who is sending?"}"/>
      </div>
      <div class="fgroup">
        <label class="flabel">${isPickup?"Receiver's Phone":"Sender's Phone"}</label>
        <input class="finput" id="otherPhone" placeholder="+1 (555) 000-0000"/>
      </div>
      <div id="addrSummary" style="display:none" class="summary"></div>
      <button class="btn-blue" onclick="confirmAddr()" style="margin-top:4px">Next →</button>
      <button class="btn-link" onclick="renderSheet(1)">← Go back</button>`;
  }

  if(step===3){
    const pickupAddr  = bookingMyRole==="pickup"  ? userAddr : bookingOther;
    const deliveryAddr= bookingMyRole==="delivery"? userAddr : bookingOther;
    h+=`
      <div class="sheet-q">Your details</div>
      <div class="sheet-hint">Tell us a bit more about yourself and the shipment.</div>
      <div class="summary">
        📦 <strong>Pickup:</strong> ${pickupAddr}<br>
        🏠 <strong>Delivery:</strong> ${deliveryAddr}
      </div>
      <div class="col2">
        <div class="fgroup"><label class="flabel">Your Full Name *</label><input class="finput" id="b_name" placeholder="e.g. John Smith"/></div>
        <div class="fgroup"><label class="flabel">Your Phone *</label><input class="finput" id="b_phone" placeholder="+1 (555) 000-0000"/></div>
      </div>
      <div class="fgroup"><label class="flabel">Your Email</label><input class="finput" id="b_email" type="email" placeholder="you@email.com"/></div>
      <div class="col2">
        <div class="fgroup"><label class="flabel">Preferred Date *</label><input class="finput" id="b_date" type="date"/></div>
        <div class="fgroup"><label class="flabel">Preferred Time</label>
          <select class="fselect" id="b_time">
            <option value="">Any time</option><option>Morning (8am–12pm)</option><option>Afternoon (12pm–5pm)</option><option>Evening (5pm–9pm)</option>
          </select>
        </div>
      </div>
      <button class="btn-blue" onclick="goToStep4()" style="margin-top:4px">Next →</button>
      <button class="btn-link" onclick="renderSheet(2)">← Go back</button>`;
  }

  if(step===4){
    const pickupAddr  = bookingMyRole==="pickup"  ? userAddr : bookingOther;
    const deliveryAddr= bookingMyRole==="delivery"? userAddr : bookingOther;
    h+=`
      <div class="sheet-q">Shipment Details</div>
      <div class="sheet-hint">Help us understand what we're moving.</div>
      <div class="col2">
        <div class="fgroup"><label class="flabel">Item Type *</label>
          <select class="fselect" id="b_itemtype">
            <option value="">Select...</option><option>Documents / Papers</option><option>Clothing / Fashion</option><option>Electronics</option><option>Food / Groceries</option><option>Furniture</option><option>Appliances</option><option>Moving Boxes</option><option>Fragile Items</option><option>Medical / Pharmacy</option><option>Other</option>
          </select>
        </div>
        <div class="fgroup"><label class="flabel">Estimated Weight</label>
          <select class="fselect" id="b_weight">
            <option value="">Select...</option><option>Under 1 kg</option><option>1 – 5 kg</option><option>5 – 20 kg</option><option>20 – 100 kg</option><option>100 kg+</option>
          </select>
        </div>
      </div>
      <div class="fgroup"><label class="flabel">Item Description *</label>
        <textarea class="ftarea" id="b_desc" placeholder="e.g. 1 large sofa, 3 medium boxes, 1 TV (packed)"></textarea>
      </div>
      <div class="col2">
        <div class="fgroup"><label class="flabel">Quantity / Number of Items</label><input class="finput" id="b_qty" placeholder="e.g. 5 boxes"/></div>
        <div class="fgroup"><label class="flabel">Package Value ($)</label><input class="finput" id="b_value" type="number" placeholder="e.g. 500"/></div>
      </div>
      <div class="fgroup">
        <label class="flabel">Special Instructions</label>
        <textarea class="ftarea" id="b_special" placeholder="e.g. Fragile, keep upright. Ring doorbell twice." style="min-height:56px"></textarea>
      </div>
      <div class="summary">
        📦 <strong>Pickup:</strong> ${pickupAddr}<br>
        🏠 <strong>Delivery:</strong> ${deliveryAddr}<br>
        🚘 <strong>Vehicle:</strong> ${activeVehicle.icon} ${activeVehicle.name}
      </div>
      <button class="btn-blue" onclick="confirmBooking()" style="margin-top:4px">Confirm Booking →</button>
      <button class="btn-link" onclick="renderSheet(3)">← Go back</button>`;
  }

  $("bookingSheet").innerHTML=h;
  if(step===2) setTimeout(()=>{const el=$("otherAddrInput");if(el){el.focus();el.addEventListener("keydown",e=>{if(e.key==="Enter")confirmAddr();});}},50);
}

function chooseRole(role){bookingMyRole=role; renderSheet(2);}

function previewSummary(){
  const val=$("otherAddrInput").value.trim();
  const box=$("addrSummary");
  if(val.length>3){
    const pu=bookingMyRole==="pickup"?userAddr:val;
    const dl=bookingMyRole==="delivery"?userAddr:val;
    box.innerHTML=`📦 <strong>Pickup:</strong> ${pu}<br>🏠 <strong>Delivery:</strong> ${dl}`;
    box.style.display="block";
  } else { box.style.display="none"; }
}

function confirmAddr(){
  const val=$("otherAddrInput")?$("otherAddrInput").value.trim():"";
  if(!val){alert("Please enter the address.");return;}
  bookingOther=val;
  bookingDetails.otherName=$("otherName")?$("otherName").value.trim():"";
  bookingDetails.otherPhone=$("otherPhone")?$("otherPhone").value.trim():"";
  renderSheet(3);
}

function goToStep4(){
  const name=$("b_name")?$("b_name").value.trim():"";
  const phone=$("b_phone")?$("b_phone").value.trim():"";
  const date=$("b_date")?$("b_date").value:"";
  if(!name||!phone){alert("Please enter your name and phone number.");return;}
  if(!date){alert("Please select a preferred date.");return;}
  bookingDetails.name=name; bookingDetails.phone=phone;
  bookingDetails.email=$("b_email")?$("b_email").value.trim():"";
  bookingDetails.date=date;
  bookingDetails.time=$("b_time")?$("b_time").value:"";
  renderSheet(4);
}

function confirmBooking(){
  const desc=$("b_desc")?$("b_desc").value.trim():"";
  const itype=$("b_itemtype")?$("b_itemtype").value:"";
  if(!itype||!desc){alert("Please select item type and describe what you're shipping.");return;}

  const tid=genId();
  const pickupAddr  = bookingMyRole==="pickup"  ? userAddr : bookingOther;
  const deliveryAddr= bookingMyRole==="delivery"? userAddr : bookingOther;

  // Save to our local "DB" so it can be tracked
  ordersDB[tid]={
    vehicle: activeVehicle.name+" "+activeVehicle.icon,
    status:"pending",
    pickupAddr, deliveryAddr,
    sender: bookingMyRole==="pickup" ? bookingDetails.name : (bookingDetails.otherName||"—"),
    receiver: bookingMyRole==="delivery" ? bookingDetails.name : (bookingDetails.otherName||"—"),
    weight: $("b_weight")?$("b_weight").value||"Not specified":"",
    notes: $("b_special")?$("b_special").value.trim():"",
    date: bookingDetails.date,
    desc: desc,
    timeline:[
      {done:true, label:"Order Placed",   time: new Date().toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"})},
      {done:false,label:"Picked Up",      time:""},
      {done:false,label:"In Transit",     time:""},
      {done:false,label:"Out for Delivery",time:""},
      {done:false,label:"Delivered",      time:""},
    ]
  };

  closeBooking();
  $("vehicleGrid").style.display="none";
  $("vgridLabel").style.display="none";
  const suc=$("bookSuccess");
  suc.classList.remove("hidden");
  $("successMsg").textContent=`Your ${activeVehicle.name} is booked! A driver will be assigned shortly. You'll receive SMS updates.`;
  $("trackId").textContent=tid;
  activeVehicle=null;
}

function resetBooking(){
  $("bookSuccess").classList.add("hidden");
  $("vehicleGrid").style.display="grid";
  $("vgridLabel").style.display="block";
  activeVehicle=null;
}

// ── TRACKING ──────────────────────────────────────────────────────
function trackOrder(){
  const raw=$("trackInput").value.trim().toUpperCase();
  const result=$("trackResult");
  const notFound=$("trackNotFound");
  result.classList.add("hidden");
  notFound.classList.add("hidden");
  if(!raw){alert("Please enter a Tracking ID.");return;}

  const order=ordersDB[raw];
  if(!order){
    notFound.classList.remove("hidden");
    return;
  }

  const statusMap={
    pending:{label:"⏳ Pending",cls:"ts-pending"},
    transit:{label:"🚚 In Transit",cls:"ts-transit"},
    delivered:{label:"✅ Delivered",cls:"ts-delivered"},
  };
  const st=statusMap[order.status]||statusMap.pending;
  const tlItems=order.timeline.map((t,i)=>{
    const isLast=i===order.timeline.length-1;
    const dotCls=t.done?(i===order.timeline.findIndex(x=>!x.done)-1?"current":"done"):"";
    return `<div class="tl-item">
      <div class="tl-dot-wrap">
        <div class="tl-dot ${dotCls}"></div>
        ${!isLast?`<div class="tl-line ${t.done?'done':''}"></div>`:''}
      </div>
      <div class="tl-text" style="padding-bottom:${isLast?'0':'12px'}">
        <strong>${t.label}</strong>${t.time?` — <span style="color:#9CA3AF">${t.time}</span>`:''}
      </div>
    </div>`;
  }).join("");

  result.innerHTML=`
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;flex-wrap:wrap;gap:8px;">
      <div style="font-size:16px;font-weight:800;color:#000;letter-spacing:1px">${raw}</div>
      <div class="track-status-badge ${st.cls}">${st.label}</div>
    </div>
    <div style="font-size:13px;color:#6B7280;margin-bottom:18px;">${order.vehicle} &nbsp;·&nbsp; Booked ${order.date||"today"}</div>
    <div class="track-info-grid">
      <div class="tinfo-card"><div class="tinfo-label">📦 Pickup</div><div class="tinfo-val">${order.pickupAddr}</div></div>
      <div class="tinfo-card"><div class="tinfo-label">🏠 Delivery</div><div class="tinfo-val">${order.deliveryAddr}</div></div>
      <div class="tinfo-card"><div class="tinfo-label">👤 Sender</div><div class="tinfo-val">${order.sender||"—"}</div></div>
      <div class="tinfo-card"><div class="tinfo-label">👤 Receiver</div><div class="tinfo-val">${order.receiver||"—"}</div></div>
      ${order.weight?`<div class="tinfo-card"><div class="tinfo-label">⚖️ Weight</div><div class="tinfo-val">${order.weight}</div></div>`:""}
      ${order.notes?`<div class="tinfo-card"><div class="tinfo-label">📝 Notes</div><div class="tinfo-val">${order.notes}</div></div>`:""}
    </div>
    <div class="track-timeline">
      <div class="tl-title">Delivery Progress</div>
      ${tlItems}
    </div>`;
  result.classList.remove("hidden");
}
$("trackInput").addEventListener("keydown",e=>{if(e.key==="Enter")trackOrder();});

// ── PARTNER ───────────────────────────────────────────────────────
function submitPartner(){
  const req=["p_name","p_phone","p_email","p_city","p_addr","p_vehicle","p_plate","p_license"];
  for(const id of req){if(!$(id)||!$(id).value.trim()){alert("Please fill in all required fields.");return;}}
  $("partnerFormWrap").classList.add("hidden");
  $("partnerSuccess").classList.remove("hidden");
  $("partnerRef").textContent=genId();
}
function resetPartner(){
  $("partnerSuccess").classList.add("hidden");
  $("partnerFormWrap").classList.remove("hidden");
  ["p_name","p_phone","p_email","p_city","p_addr","p_plate","p_license","p_idnum","p_make","p_year"].forEach(id=>{if($(id))$(id).value="";});
  ["p_exp","p_vehicle","p_idtype"].forEach(id=>{if($(id))$(id).selectedIndex=0;});
}
</script>
